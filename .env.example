# FORA — Environment Variables
# Copy this file to .env and fill in your values.
# Or run ./setup.sh — it walks you through everything conversationally.
#
# None of these are required to use FORA.
# AI provider and Vercel are INDEPENDENT — only fill in what your option needs.
# See README.md → Usage options for the full picture.
#
# Option 1 (fully manual):              no .env needed at all
# Option 2 (manual codegen, auto deploy): VERCEL_TOKEN + VERCEL_PROJECT_NAME only
# Option 3 (auto codegen, manual deploy): one AI key only (Anthropic, Gemini, or OpenAI)
# Option 4 (fully automated):           one AI key + VERCEL_TOKEN + VERCEL_PROJECT_NAME

# ── AI provider — Options 3 + 4 only ────────────────────────────────────────
# Add ONE of the following. FORA auto-detects which provider to use.
# Priority if multiple keys are set: Anthropic → Gemini → OpenAI
# (or set AI_PROVIDER explicitly to force a specific one)
#
# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — override which model to use. Defaults per provider:
#   Anthropic → claude-opus-4-5
#   Gemini    → gemini-2.0-flash
#   OpenAI    → gpt-4o
AI_MODEL=

# Optional — force a specific provider (anthropic | gemini | openai)
# Only needed if you have multiple keys set and want to control which one is used.
AI_PROVIDER=

# ── Vercel — Options 2 + 4 only ─────────────────────────────────────────────
# Required for generate.js --deploy and --publish (automated Vercel deploy)
# NOT required for generate.js --run
# Get your token at: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Your personal Vercel project name — set this to your name, not "fora-pages"
# This becomes your deploy URL: https://[name].vercel.app/[company]
# e.g. VERCEL_PROJECT_NAME=meet-shah → meet-shah.vercel.app/nola
# run ./setup.sh and it will suggest your name automatically from profile.json
VERCEL_PROJECT_NAME=

# Optional — custom domain if you have one (e.g. apply.yourname.com)
DEPLOY_DOMAIN=

# ── Optional ─────────────────────────────────────────────────────────────────
# PostHog analytics — tracks page views per application (V1 feature)
POSTHOG_API_KEY=
