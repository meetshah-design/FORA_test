# FORA — Environment Variables
# Copy this file to .env and fill in your values.
#
# None of these are required to use FORA.
# AI provider and Vercel are INDEPENDENT — only fill in what your mode needs.
# See README.md → Usage modes for the full picture.
#
# Mode 1  (fully manual):                no .env needed at all
# Mode 2A (auto codegen):                one AI key only (Anthropic, Gemini, or OpenAI)
# Mode 2B (manual codegen, auto deploy): VERCEL_TOKEN + VERCEL_PROJECT_NAME only
# Mode 3  (fully automated):             one AI key + VERCEL_TOKEN + VERCEL_PROJECT_NAME

# ── AI provider — Mode 2A + 3 only ──────────────────────────────────────────
# Add ONE of the following. FORA auto-detects which provider to use.
# Priority if multiple keys are set: Anthropic → Gemini → OpenAI
# (or set AI_PROVIDER explicitly to force a specific one)
#
# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — override which model to use. Defaults per provider:
#   Anthropic → claude-opus-4-5
#   Gemini    → gemini-2.0-flash
#   OpenAI    → gpt-4o
AI_MODEL=

# Optional — force a specific provider (anthropic | gemini | openai)
# Only needed if you have multiple keys set and want to control which one is used.
AI_PROVIDER=

# ── Vercel — Mode 2B + 3 only ───────────────────────────────────────────────
# Required for generate.js --deploy and --publish (automated Vercel deploy)
# NOT required for generate.js --run
# Get your token at: https://vercel.com/account/tokens
VERCEL_TOKEN=

# The name of your Vercel project (FORA creates it automatically on first deploy)
VERCEL_PROJECT_NAME=fora-pages

# Optional — custom domain if you have one (e.g. apply.yourname.com)
DEPLOY_DOMAIN=

# ── Optional ─────────────────────────────────────────────────────────────────
# PostHog analytics — tracks page views per application (V1 feature)
POSTHOG_API_KEY=
