# FORA — Environment Variables
# Copy this file to .env and fill in your values.
#
# None of these are required to use FORA.
# Anthropic and Vercel are INDEPENDENT — only fill in what your mode needs.
# See README.md → Usage modes for the full picture.
#
# Mode 1  (fully manual):              no .env needed at all
# Mode 2A (auto codegen):              ANTHROPIC_API_KEY only
# Mode 2B (manual codegen, auto deploy): VERCEL_TOKEN + VERCEL_PROJECT_NAME only  ← no Anthropic needed
# Mode 3  (fully automated):           ANTHROPIC_API_KEY + VERCEL_TOKEN + VERCEL_PROJECT_NAME

# ── Anthropic — Mode 2A + 3 only ────────────────────────────────────────────
# Required for generate.js --run and --publish (automated codegen)
# NOT required for generate.js --deploy
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — which model to use for codegen. Any model with a large context window works.
# Defaults to claude-opus-4-5 if not set.
AI_MODEL=

# ── Vercel — Mode 2B + 3 only ───────────────────────────────────────────────
# Required for generate.js --deploy and --publish (automated Vercel deploy)
# NOT required for generate.js --run
# Get your token at: https://vercel.com/account/tokens
VERCEL_TOKEN=

# The name of your Vercel project (create it once at vercel.com/new)
VERCEL_PROJECT_NAME=fora-pages

# Optional — custom domain if you have one (e.g. apply.yourname.com)
DEPLOY_DOMAIN=

# ── Optional ─────────────────────────────────────────────────────────────────
# PostHog analytics — tracks page views per application (V1 feature)
POSTHOG_API_KEY=
