# Environment
.env
.env.local

# ── PERSONAL FILES (local only — never committed) ──────────────────────────
# Your actual profile — the template is committed, your data is not
profile/profile.json

# Your actual design system — the example is committed, yours is not
design-system/default.md

# Your actual application briefs — example-brief.json is committed, yours are not
briefs/*.json
!briefs/example-brief.json

# Your application history — schema file is committed, your data is not
applications/applications.json

# Run state files (local only)
run.json

# ── GENERATED OUTPUT (never committed) ────────────────────────────────────
output/

# ── DESIGN SYSTEM PERSONAL OVERRIDES ──────────────────────────────────────
design-system/user.css

# ── NODE ───────────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── EDITOR ─────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── LOGS ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
